{
  "name": "nutrition-app",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "web": "expo start --web",
    "tunnel": "expo start --tunnel",
    "test": "jest",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@gorhom/bottom-sheet": "^5.0.6",
    "expo": "~56.0.12",
    "expo-router": "~56.2.11",
    "expo-sqlite": "~56.0.5",
    "react": "18.3.1",
    "react-dom": "19.2.7",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-reanimated": "~4.4.1",
    "react-native-safe-area-context": "~4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-web": "~0.19.13",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/react-native": "^13.2.0",
    "@types/jest": "^29.5.14",
    "@types/react": "^18.3.12",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.0",
    "react-test-renderer": "18.3.1",
    "typescript": "^6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "testEnvironment": "node",
    "testMatch": [
      "**/src/**/*.test.ts",
      "**/src/**/*.test.tsx"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@gorhom/.*|zustand))"
    ]
  }
}

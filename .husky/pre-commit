#!/bin/sh

# 1. Prettier + ESLint on staged files only (fast, fail early)
npx lint-staged || exit 1

# 2. Full TypeScript type check
npm run typecheck || exit 1

# 3. Unit tests
npm run test -- --passWithNoTests || exit 1

# 4. Domain layer boundary enforcement
sh scripts/check-domain-boundaries.sh || exit 1

# 5. Seed JSON schema validation
node scripts/validate-seed-json.js || exit 1
